# TealTiger Governance Sidecar — Python Production Image
# Language-agnostic HTTP governance API wrapping TealEngine v1.2
#
# Usage:
#   docker build -f Dockerfile.sidecar -t tealtigeradmin/tealtiger-python:1.2-governance .
#   docker run -p 8080:8080 tealtigeradmin/tealtiger-python:1.2-governance
#
# Environment variables:
#   TEALTIGER_PORT          HTTP port (default: 8080)
#   TEALTIGER_HOST          Bind address (default: 0.0.0.0)
#   TEALTIGER_MODE          Policy mode: ENFORCE | MONITOR | REPORT_ONLY (default: ENFORCE)
#   TEALTIGER_POLICY_DIR    Path to policy JSON files (default: /etc/tealtiger/policies)
#   TEALTIGER_LOG_LEVEL     Log level: info | debug | warn | error (default: info)
#   TEALTIGER_MAX_BODY_BYTES Max request body size in bytes (default: 1048576)
#
# Policy mounting:
#   docker run -v ./my-policies:/etc/tealtiger/policies tealtigeradmin/tealtiger-python:1.2-governance

# ── Stage 1: Builder ─────────────────────────────────────────────
FROM python:3.11-slim AS builder

LABEL maintainer="TealTiger Team <reachout@tealtiger.ai>"
LABEL description="TealTiger Governance Sidecar — TealEngine v1.2 Python HTTP API"

WORKDIR /build

# Install build dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends gcc g++ && \
    rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml README.md LICENSE ./
COPY src/ ./src/

# Build wheel
RUN pip install --no-cache-dir build && \
    python -m build --wheel

# ── Stage 2: Runtime ─────────────────────────────────────────────
FROM python:3.11-slim

WORKDIR /app

# Install runtime system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates wget && \
    rm -rf /var/lib/apt/lists/*

# Copy wheel from builder and install
COPY --from=builder /build/dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl && \
    rm -rf /tmp/*.whl /root/.cache

# Create non-root user
RUN useradd -m -u 1001 -s /bin/bash tealtiger

# Create policy directory
RUN mkdir -p /etc/tealtiger/policies && \
    chown -R tealtiger:tealtiger /etc/tealtiger && \
    chown -R tealtiger:tealtiger /app

# Switch to non-root user
USER tealtiger

# Environment defaults
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    TEALTIGER_PORT=8080 \
    TEALTIGER_HOST=0.0.0.0 \
    TEALTIGER_MODE=ENFORCE \
    TEALTIGER_POLICY_DIR=/etc/tealtiger/policies \
    TEALTIGER_LOG_LEVEL=info

# Expose HTTP port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost:8080/health || exit 1

# Volume for policy files
VOLUME ["/etc/tealtiger/policies"]

# Copy the sidecar server script to a known location for direct execution
COPY --from=builder /build/src/tealtiger/sidecar/server.py /app/server.py

# Start the sidecar server directly (avoids triggering tealtiger/__init__.py)
CMD ["python", "/app/server.py"]
