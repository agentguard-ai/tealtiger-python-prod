# TealTiger Python SDK - Jupyter Notebook Image
# Interactive environment for experimentation and tutorials

FROM python:3.11-slim

LABEL maintainer="TealTiger Team <support@tealtiger.co.in>"
LABEL description="TealTiger Python SDK - Jupyter Notebook Environment"

WORKDIR /app

# Install system dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml README.md LICENSE ./
COPY src/ ./src/
COPY examples/ ./examples/

# Install TealTiger SDK and Jupyter
RUN pip install --no-cache-dir \
    -e . \
    jupyter \
    jupyterlab \
    ipywidgets \
    matplotlib \
    pandas \
    && rm -rf /root/.cache

# Create notebooks directory
RUN mkdir -p /app/notebooks

# Create non-root user
RUN useradd -m -u 1000 -s /bin/bash tealtiger && \
    chown -R tealtiger:tealtiger /app

USER tealtiger

# Expose Jupyter port
EXPOSE 8888

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Start Jupyter Lab
CMD ["jupyter", "lab", "--ip=0.0.0.0", "--port=8888", "--no-browser", "--allow-root"]
