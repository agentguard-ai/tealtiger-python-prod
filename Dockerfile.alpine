# TealTiger Python SDK - Alpine Image
# Minimal image size for production deployments

FROM python:3.11-alpine as builder

WORKDIR /build

# Install build dependencies
RUN apk add --no-cache \
    gcc \
    musl-dev \
    linux-headers

# Copy project files
COPY pyproject.toml README.md LICENSE ./
COPY src/ ./src/

# Build wheel
RUN pip install --no-cache-dir build && \
    python -m build --wheel

# Runtime stage
FROM python:3.11-alpine

WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache ca-certificates

# Copy wheel and install
COPY --from=builder /build/dist/*.whl /tmp/
RUN pip install --no-cache-dir /tmp/*.whl && \
    rm -rf /tmp/*.whl /root/.cache

# Copy examples
COPY examples/ /app/examples/
COPY README.md LICENSE /app/

# Create non-root user
RUN addgroup -g 1000 tealtiger && \
    adduser -D -u 1000 -G tealtiger tealtiger && \
    chown -R tealtiger:tealtiger /app

USER tealtiger

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

CMD ["python"]
